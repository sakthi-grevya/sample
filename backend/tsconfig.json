{
  "compilerOptions": {
    "target": "ES2022",                                  /* Modern JS support for Node 24 */
    "module": "NodeNext",                                /* Best for pnpm and modern ESM */
    "moduleResolution": "NodeNext",
    "outDir": "./dist",                                  /* Where your compiled files go */
    "rootDir": "./src",                                  /* Explicitly set source folder */
    "esModuleInterop": true,                             /* Fixes imports for libraries like Express */
    "forceConsistentCasingInFileNames": true,            
    "strict": true,                                      /* Enable all strict type-checking */
    "noImplicitAny": true,
    "sourceMap": true,                                   /* Good for debugging */
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "resolveJsonModule": true,
    "skipLibCheck": true                                 /* Faster compilation */
  },
  "include": ["src/**/*"],                               /* Simplified: covers all .ts files in src */
  "exclude": ["node_modules", "dist"]
}